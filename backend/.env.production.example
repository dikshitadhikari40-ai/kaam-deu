# ============================================
# KAAM DEU BACKEND - PRODUCTION ENVIRONMENT
# Copy this to .env.production and fill in values
# ============================================

# Server Configuration
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# Supabase Configuration (REQUIRED)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key-here

# JWT Secret (REQUIRED - use a strong random string)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters

# LinkedIn OAuth (REQUIRED for LinkedIn login)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# eSewa Payment Configuration (REQUIRED for payments)
ESEWA_MERCHANT_ID=your-esewa-merchant-id
ESEWA_MERCHANT_SECRET=your-esewa-merchant-secret
ESEWA_PRODUCTION=true

# App Configuration
APP_REDIRECT_SCHEME=kaamdeu
API_BASE_URL=https://api.kaamdeu.com

# CORS - Allowed Origins (comma-separated)
ALLOWED_ORIGINS=https://kaamdeu.com,https://app.kaamdeu.com

# Database Path (for local SQLite, optional in production)
DB_PATH=/app/data/kaamdeu.db

# Sentry Error Reporting (REQUIRED for production monitoring)
SENTRY_DSN=your-sentry-dsn-here
