# ============================================
# KAAM DEU FRONTEND - PRODUCTION ENVIRONMENT
# Copy this to .env.production and fill in values
# ============================================

# Supabase Configuration (REQUIRED)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Backend API URL (REQUIRED)
EXPO_PUBLIC_API_URL=https://api.kaamdeu.com
EXPO_PUBLIC_PUBLIC_BASE_URL=https://api.kaamdeu.com

# Google OAuth (REQUIRED for Google login)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id.apps.googleusercontent.com

# LinkedIn OAuth (REQUIRED for LinkedIn login)
EXPO_PUBLIC_LINKEDIN_CLIENT_ID=your-linkedin-client-id

# Agora Configuration (REQUIRED for voice/video calls)
EXPO_PUBLIC_AGORA_APP_ID=your-agora-app-id

# eSewa Configuration (payments handled by backend)
# Frontend only needs the app to open eSewa

# Sentry Error Reporting (REQUIRED for production monitoring)
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
